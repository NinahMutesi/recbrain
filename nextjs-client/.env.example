# ── Public (exposed to browser) ──────────────────────────────────
# URL of your existing server.js (Socket.IO chatbot server)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ── Server-only (NEVER exposed to browser) ──────────────────────
# Used by /api/sync and /api/history routes

APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here
APPWRITE_DATABASE_ID=recbrain_db
APPWRITE_COLLECTION_ID=chat_messages
APPWRITE_KNOWLEDGE_COLLECTION_ID=rec_knowledge

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rec_conference

OLLAMA_URL=http://localhost:11434

# Optional: protects /api/sync from being called by randoms
# Generate any random string, e.g. with: openssl rand -hex 16
SYNC_SECRET=replace_with_a_random_secret
